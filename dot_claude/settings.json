{
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "sonnet[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/uncool/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/uncool/.claude/hooks/caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/uncool/.claude/hooks/caveman-statusline.sh\""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "cc-skills-golang@samber": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "samber": {
      "source": {
        "source": "github",
        "repo": "samber/cc"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "availableModels": [
    "claude-sonnet-4-6[1m]",
    "claude-sonnet-4-6",
    "claude-haiku-4-5"
  ],
  "allow": [
    "Bash(git push *)",
    "Bash(git push)",
    "Bash(git commit *)",
    "Bash(git add *)",
    "Bash(git fetch *)",
    "Bash(git pull *)",
    "Bash(git checkout *)",
    "Bash(git switch *)",
    "Bash(git stash *)",
    "Bash(git merge *)",
    "Bash(git rebase *)",
    "Bash(git cherry-pick *)",
    "Bash(git revert *)",
    "Bash(git tag *)",
    "Bash(git restore --staged *)"
  ],
  "enforceAvailableModels": true,
  "effortLevel": "medium",
  "tui": "fullscreen",
  "theme": "dark-ansi",
  "preferredNotifChannel": "ghostty",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
