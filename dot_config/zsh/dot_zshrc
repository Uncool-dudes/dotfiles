# ── Zsh Options ─────────────────────────────────────────────────
setopt CORRECT
setopt GLOB_DOTS
setopt NO_CASE_GLOB
setopt PIPE_FAIL
setopt INTERACTIVE_COMMENTS

# ── Completion ──────────────────────────────────────────────────
# Cache compinit — only re-check once per day, skip compaudit entirely
autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}'

# ── Environment ─────────────────────────────────────────────────
export EDITOR='nvim'
export VISUAL='nvim'
export LG_CONFIG_FILE="$HOME/.config/lazygit/config.yml"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

. "$HOME/.cargo/env"

typeset -U path
path=(
  "$HOME/.local/bin"
  "$HOME/go/bin"
  "$HOME/.cargo/bin"
  "$HOME/.pnpm-global/bin"
  /opt/homebrew/bin   # macOS: ensure brew bins are available early
  $path
)

# ── Antidote ────────────────────────────────────────────────────
if [[ "$(uname)" == "Darwin" ]]; then
  source "/opt/homebrew/opt/antidote/share/antidote/antidote.zsh"
elif [[ -f /usr/share/zsh-antidote/antidote.zsh ]]; then
  source /usr/share/zsh-antidote/antidote.zsh
fi

# Source pre-built static bundle (faster than antidote load at runtime)
# Run zsh-update-plugins to rebuild after editing .zsh_plugins.txt
zsh_plugins="${ZDOTDIR:-$HOME}/.zsh_plugins.zsh"
if [[ ! -f "$zsh_plugins" ]]; then
  antidote bundle < "${ZDOTDIR:-$HOME}/.zsh_plugins.txt" > "$zsh_plugins"
fi
source "$zsh_plugins"

# ── Aliases ─────────────────────────────────────────────────────
alias lz='lazygit'
alias cat='bat'
alias mkdir='mkdir -p'
alias ls='eza'
alias ll='eza --icons --git'
alias lt='eza --icons --git --tree'
alias diff='delta'
alias cc='claude'
alias ccc='claude --continue'
alias ccr='claude --resume'
alias cch='CLAUDE_CONFIG_DIR=~/.claude-home claude'

alias ..='cd ..'
alias ...='cd ../..'

# Systemctl (Arch)
alias sc-start='sudo systemctl start'
alias sc-stop='sudo systemctl stop'
alias sc-reload='sudo systemctl reload'
alias sc-restart='sudo systemctl restart'
alias sc-try-restart='sudo systemctl try-restart'
alias sc-enable='sudo systemctl enable'
alias sc-disable='sudo systemctl disable'
alias sc-reenable='sudo systemctl reenable'

# Global pipes
alias -g G='| rg'
alias -g L='| less'
alias -g H='| head'
alias -g T='| tail'
alias -g C='| wc -l'
alias -g J='| jq .'
alias -g S='| sort'
alias -g U='| sort -u'
alias -g F='| fzf'

# Global redirects
alias -g NE='2>/dev/null'
alias -g NUL='>/dev/null 2>&1'

# ── Functions ───────────────────────────────────────────────────
# Arch system upgrade with keyring check
function upgrade() {
  sudo pacman -Sy

  echo ":: Checking Arch Linux PGP Keyring..."
  local installedver="$(LANG= sudo pacman -Qi archlinux-keyring | grep -Po '(?<=Version         : ).*')"
  local currentver="$(LANG= sudo pacman -Si archlinux-keyring | grep -Po '(?<=Version         : ).*')"

  if [ "$installedver" != "$currentver" ]; then
    echo " Arch Linux PGP Keyring is out of date."
    echo " Updating before full system upgrade."
    sudo pacman -S --needed --noconfirm archlinux-keyring
  else
    echo " Arch Linux PGP Keyring is up to date."
    echo " Proceeding with full system upgrade."
  fi

  if (( $+commands[yay] )); then
    yay -Su
  elif (( $+commands[paru] )); then
    paru -Su
  else
    sudo pacman -Su
  fi
}

# Auto activate Python venv on cd
function auto_venv() {
  if [[ -d .venv ]]; then
    [[ "$VIRTUAL_ENV" != "$PWD/.venv" ]] && source .venv/bin/activate
  elif [[ -d venv ]]; then
    [[ "$VIRTUAL_ENV" != "$PWD/venv" ]] && source venv/bin/activate
  elif [[ -n "$VIRTUAL_ENV" ]]; then
    [[ "$PWD" != "${VIRTUAL_ENV%/*}"* ]] && deactivate
  fi
}
add-zsh-hook chpwd auto_venv

# Kill process interactively
function fp() { ps aux | fzf --height 40% | awk '{print $2}' | xargs -r kill -9 }

# Kill port interactively
function fk() { ss -tlnp 2>/dev/null | fzf --height 40% }

# Compress with zstd
function tarzst() {
  tar --use-compress-program=zstd -cvf "${1}.tar.zst" "$1"
}

# Rebuild antidote bundle and reload shell
function zsh-update-plugins() {
  antidote bundle < "${ZDOTDIR:-$HOME}/.zsh_plugins.txt" > "${ZDOTDIR:-$HOME}/.zsh_plugins.zsh"
  exec zsh
}

# ── Cached eval ─────────────────────────────────────────────────
# Runs tool once, caches output, re-generates only when binary changes
_cache_eval() {
  local name="$1"
  local cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/${name}.zsh"
  local bin="${commands[$name]:-$(whence $name 2>/dev/null)}"
  if [[ ! -f "$cache" || -z "$bin" || "$cache" -ot "$bin" ]]; then
    mkdir -p "${cache:h}"
    "$name" "${@:2}" > "$cache" 2>/dev/null
  fi
  [[ -f "$cache" ]] && source "$cache"
}

_cache_eval chezmoi completion zsh
_cache_eval pnpm    completion zsh
_cache_eval mise    completion zsh
_cache_eval zoxide  init zsh --cmd cd
_cache_eval direnv  hook zsh
_cache_eval atuin   init zsh

# ── SSH (macOS) ──────────────────────────────────────────────────
# No plugin needed — add to ~/.ssh/config:
#   Host *
#     UseKeychain yes
#     AddKeysToAgent yes

# ── Prompt ──────────────────────────────────────────────────────
if (( $+commands[starship] )); then
  _cache_eval starship init zsh
fi

# ── Keybindings ─────────────────────────────────────────────────
export WORDCHARS=''

bindkey '^[[1;3C' forward-word
bindkey '^[[1;3D' backward-word
